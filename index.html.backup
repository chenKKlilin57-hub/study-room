<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>稀奇小杰泥自习室</title>
  <style>
    :root {
      --bg:#f6f3ee;
      --card:#ffffffcc;
      --line:#00000014;
      --text:#2c2724;
      --muted:#7a726c;
      --accent:#b46b5d;
      --danger:#b95f5f;
      --ok:#5e8b68;

      /* 统一阴影系统 */
      --shadow-light: 0 8px 24px rgba(49,32,24,.06);
      --shadow-medium: 0 18px 50px rgba(49,32,24,.10);
      --shadow-heavy: 0 24px 60px rgba(49,32,24,.16);

      /* 统一圆角系统 */
      --radius-card: 20px;
      --radius-button: 12px;

      /* 统一间距系统 */
      --spacing-card: 24px;
      --spacing-section: 20px;
    }

    body.dark {
      --bg:#151515;
      --card:#222222d0;
      --line:#ffffff12;
      --text:#f4efe8;
      --muted:#a89f97;
      --accent:#d88a7d;
      --danger:#de7c7c;
      --ok:#8fc39c;

      /* 深色模式阴影 */
      --shadow-light: 0 8px 24px rgba(0,0,0,.20);
      --shadow-medium: 0 18px 50px rgba(0,0,0,.35);
      --shadow-heavy: 0 24px 60px rgba(0,0,0,.50);
    }

    * { box-sizing:border-box; }
    html, body { margin:0; min-height:100%; }

    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top left, rgba(212,180,172,.35), transparent 28%),
        radial-gradient(circle at bottom right, rgba(180,107,93,.12), transparent 28%),
        var(--bg);
      transition: background 0.3s ease;
    }

    .wrap {
      width:min(1160px, calc(100% - 28px));
      margin:24px auto 40px;
      transition: all 0.3s ease;
    }

    .app {
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--radius-card);
      backdrop-filter:blur(16px);
      box-shadow:var(--shadow-medium);
      overflow:hidden;
      transition: all 0.3s ease;
    }

    .topbar {
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:18px 22px;
      border-bottom:1px solid var(--line);
      gap:16px;
    }

    .brand small {
      display:block;
      color:var(--muted);
      font-size:12px;
      letter-spacing:.08em;
      margin-bottom:6px;
    }

    .brand h1 {
      margin:0;
      font-size:25px;
      letter-spacing:-.02em;
    }

    .toolbar {
      display:flex;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .chip, .btn, .icon-btn, input {
      border:1px solid var(--line);
      background:var(--card);
      color:var(--text);
      border-radius:var(--radius-button);
    }

    .chip {
      padding:10px 12px;
      font-size:13px;
    }

    .icon-btn {
      width:42px;
      height:42px;
      cursor:pointer;
    }

    .btn {
      padding:12px 18px;
      cursor:pointer;
      font-size:14px;
      transition:all .18s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-light);
    }

    .btn.primary {
      background:linear-gradient(135deg, var(--accent), #c98b7c);
      color:#fff;
      border:none;
    }

    .btn.primary:hover {
      box-shadow: var(--shadow-medium);
    }

    .btn.primary:active {
      transform: scale(0.96);
    }

    .btn.ghost {
      background:transparent;
    }
    
    .time-btn-active {
      background: linear-gradient(135deg, var(--accent), #c98b7c) !important;
      color: #fff !important;
      border: none !important;
    }

    .layout {
      display:grid;
      grid-template-columns:1.02fr .98fr;
    }

    .left, .right {
      padding:var(--spacing-card);
    }

    .right {
      border-left:1px solid var(--line);
    }

    .hero-note, .muted {
      color:var(--muted);
    }

    .hero-note {
      font-size:14px;
      margin-bottom:18px;
    }

    .card {
      border:1px solid var(--line);
      background:var(--card);
      border-radius:var(--radius-card);
      padding:var(--spacing-card);
      box-shadow: var(--shadow-light);
      transition: box-shadow 0.2s ease;
    }

    .card:hover {
      box-shadow: var(--shadow-medium);
    }

    .checkin-card {
      margin-bottom: 20px;
      background: linear-gradient(135deg, rgba(180,107,93,0.05), transparent);
    }
    .checkin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }
    .checkin-date {
      font-size: 13px;
      font-weight: 500;
    }
    .checkin-stats {
      font-size: 14px;
      color: var(--muted);
    }
    .checkin-stats b {
      background: linear-gradient(90deg, #b46b5d, #d88a7d);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 20px;
      font-weight: bold;
    }
    body.dark .checkin-stats b {
      background: linear-gradient(90deg, #d88a7d, #eabeb6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .mode {
      display:inline-flex;
      align-items:center;
      font-size:12px;
      color:var(--accent);
      padding:8px 12px;
      border-radius:999px;
      background:rgba(180,107,93,.09);
    }

    .timer {
      font-size:clamp(58px, 11vw, 116px);
      line-height:1;
      letter-spacing:-.06em;
      margin:18px 0 12px;
      font-weight:700;
      font-variant-numeric: tabular-nums;
      text-align:center;
      transition: all 0.4s ease;
    }

    .status {
      text-align:center;
      color:var(--muted);
      font-size:15px;
      margin-bottom:20px;
    }

    .controls {
      display:flex;
      gap:12px;
      justify-content:center;
      flex-wrap:wrap;
    }

    .stats {
      display:grid;
      grid-template-columns:repeat(3, 1fr);
      gap:20px;
      margin-top:var(--spacing-section);
    }

    .stat {
      border:1px solid var(--line);
      border-radius:var(--radius-card);
      padding:var(--spacing-card);
      background:linear-gradient(135deg, rgba(180,107,93,0.03), transparent);
      transition: all 0.2s ease;
    }

    .stat:hover {
      background:linear-gradient(135deg, rgba(180,107,93,0.06), transparent);
      transform: translateY(-2px);
      box-shadow: var(--shadow-light);
    }

    .stat .k {
      font-size:13px;
      color:var(--muted);
      margin-bottom:8px;
    }

    .stat .v {
      font-size:26px;
      font-weight:700;
      letter-spacing:-.02em;
      font-variant-numeric: tabular-nums;
    }
    }

    .subject-stats-card {
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--radius-card);
      padding:20px;
      margin-top:var(--spacing-section);
    }

    .subject-stats-header {
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:16px;
      flex-wrap:wrap;
      gap:12px;
    }

    .subject-stats-header h3 {
      margin:0;
      font-size:16px;
      font-weight:600;
    }

    .subject-stats-tabs {
      display:flex;
      gap:6px;
      background:var(--bg);
      padding:4px;
      border-radius:10px;
    }

    .subject-stats-tab {
      padding:6px 12px;
      font-size:12px;
      border:none;
      background:transparent;
      color:var(--muted);
      border-radius:8px;
      cursor:pointer;
      transition:all 0.2s;
    }

    .subject-stats-tab.active {
      background:var(--card);
      color:var(--text);
    }

    .subject-item {
      display:flex;
      align-items:center;
      gap:12px;
      padding:10px 0;
      border-bottom:1px solid var(--line);
    }

    .subject-item:last-child {
      border-bottom:none;
    }

    .subject-name {
      min-width:80px;
      font-size:14px;
      color:var(--text);
    }

    .subject-bar-container {
      flex:1;
      height:8px;
      background:var(--bg);
      border-radius:4px;
      overflow:hidden;
    }

    .subject-bar {
      height:100%;
      background:linear-gradient(90deg, var(--accent), #d88a7d);
      border-radius:4px;
      transition:width 0.8s cubic-bezier(.4,0,.2,1);
    }

    .subject-duration {
      min-width:60px;
      text-align:right;
      font-size:13px;
      color:var(--muted);
    }

    .subject-empty {
      text-align:center;
      padding:20px;
      color:var(--muted);
      font-size:14px;
    }

    .stat .v {
      font-size:28px;
      font-weight:700;
    }

    .tabs {
      display:flex;
      gap:8px;
      margin-bottom:16px;
      flex-wrap:wrap;
    }

    .tab {
      padding:10px 14px;
      border-radius:var(--radius-button);
      cursor:pointer;
      border:1px solid var(--line);
      background:transparent;
      color:var(--text);
    }

    .tab.active {
      background:var(--card);
    }

    .section-title {
      display:flex;
      justify-content:space-between;
      align-items:end;
      gap:12px;
      margin-bottom:14px;
    }

    .section-title h2 {
      margin:0;
      font-size:22px;
    }

    .section-title p {
      margin:6px 0 0;
      color:var(--muted);
      font-size:14px;
    }

    .row {
      display:flex;
      gap:10px;
    }

    input[type="text"], input[type="email"], input[type="password"], input[type="date"] {
      width:100%;
      padding:14px 16px;
      font-size:15px;
      outline:none;
    }
    
    body.dark input[type="date"] {
      color-scheme: dark;
    }

    .list {
      display:flex;
      flex-direction:column;
      gap:10px;
      max-height:370px;
      overflow:auto;
    }

    .item {
      display:flex;
      gap:12px;
      align-items:center;
      padding:14px;
      border:1px solid var(--line);
      border-radius:var(--radius-card);
      background:var(--card);
      transition: all 0.2s ease;
    }
    
    .item.me {
      border-color: var(--accent);
      background: linear-gradient(90deg, rgba(180,107,93,0.08), transparent);
    }

    .item .main {
      flex:1;
    }

    .task-done .task-text {
      text-decoration:line-through;
      color:var(--muted);
    }

    .priority-badge {
      display:inline-block;
      width:8px;
      height:8px;
      border-radius:50%;
      margin-right:8px;
    }

    .priority-high { background:#ef4444; }
    .priority-medium { background:#f59e0b; }
    .priority-low { background:#9ca3af; }

    .item.task-priority-high {
      background: linear-gradient(90deg, rgba(239,68,68,0.12), rgba(239,68,68,0.05));
      border-color: rgba(239,68,68,0.3);
    }

    .item.task-priority-high .task-text {
      font-weight: 500;
    }

    .item.task-priority-medium {
      background: linear-gradient(90deg, rgba(245,158,11,0.1), rgba(245,158,11,0.03));
      border-color: rgba(245,158,11,0.25);
    }

    .item.task-priority-low {
      background: rgba(156,163,175,0.03);
      border-color: rgba(156,163,175,0.15);
    }

    .item.task-priority-low .task-text {
      color: var(--muted);
    }

    .item.task-done {
      background: rgba(0,0,0,0.02) !important;
      border-color: var(--line) !important;
      opacity: 0.6;
    }

    .task-time {
      font-size:12px;
      color:var(--muted);
      margin-left:8px;
    }

    .task-header {
      display:flex;
      align-items:center;
      gap:8px;
    }

    .task-total-time {
      margin-top:12px;
      padding:12px;
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--radius-button);
      font-size:14px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .task-total-time.overload {
      border-color:#ef4444;
      background:rgba(239,68,68,0.05);
    }

    .task-total-time .warning {
      color:#ef4444;
      font-size:12px;
    }

    .danger {
      color:var(--danger);
    }

    .hidden {
      display:none !important;
    }

    .auth-box {
      max-width:460px;
      margin:10px auto 0;
    }

    .auth-note, .quote {
      font-size:13px;
      color:var(--muted);
      line-height:1.6;
    }

    .quote {
      text-align:center;
      margin-top:18px;
    }

    .crown {
      font-size:18px;
    }

    .ok-banner {
      margin-bottom:14px;
      padding:12px 14px;
      border-radius:var(--radius-button);
      border:1px solid var(--line);
      background:var(--card);
      font-size:13px;
      color:var(--muted);
    }

    .app-status {
      margin-top:10px;
      font-size:13px;
      color:var(--muted);
    }

    .app-status.error {
      color:var(--danger);
    }

    .app-status.ok {
      color:var(--ok);
    }

    .ok {
      color: var(--ok) !important;
    }

    .loading {
      opacity:.7;
      pointer-events:none;
    }

    .disabled {
      opacity:.5;
      pointer-events:none;
    }

    /* 撤销 Toast */
    .undo-toast {
      position: fixed;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--text);
      color: var(--bg);
      padding: 14px 20px;
      border-radius: var(--radius-card);
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 14px;
      box-shadow: 0 8px 30px rgba(0,0,0,.2);
      z-index: 2000;
      opacity: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
      white-space: nowrap;
    }
    .undo-toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    .undo-toast-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      background: var(--accent);
      border-radius: 0 0 16px 16px;
      width: 100%;
      transform-origin: left;
      animation: toast-countdown 5s linear forwards;
    }
    @keyframes toast-countdown {
      from { transform: scaleX(1); }
      to   { transform: scaleX(0); }
    }
    .undo-toast button {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 6px 14px;
      font-size: 13px;
      cursor: pointer;
      font-weight: 600;
    }

    /* 🔥 沉浸模式样式 */
    body.immersive .topbar,
    body.immersive .right,
    body.immersive .ok-banner,
    body.immersive .stats,
    body.immersive .quote,
    body.immersive #editGoalBtn,
    body.immersive #appStatus,
    body.immersive .hero-note,
    body.immersive .card:not(.focus-card) {
      display: none !important;
    }
    body.immersive .layout {
      grid-template-columns: 1fr;
      padding: 0;
      height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    body.immersive .left {
      padding: 0;
      width: 100%;
    }
    body.immersive .app {
      border: none;
      box-shadow: none;
      background: transparent;
      backdrop-filter: none;
    }
    body.immersive .focus-card {
      border: none;
      background: transparent;
      box-shadow: none;
      transform: scale(1.1);
    }
    body.immersive .timer {
      font-size: clamp(80px, 15vw, 160px);
    }

    /* 🔥 页面切换及热力图专属样式 */
    .page {
      display: block;
      animation: fadeIn 0.3s ease;
    }

    .page.hidden-page {
      display: none !important;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .subpage-topbar {
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:16px;
      flex-wrap:wrap;
    }

    .heatmap-page-wrap {
      width:min(1160px, calc(100% - 28px));
      margin:24px auto 40px;
    }

    .heatmap-grid-wrap {
      overflow-x:auto;
      padding-bottom:8px;
    }

    .heatmap-grid {
      display:grid;
      grid-auto-flow:column;
      grid-auto-columns:14px;
      grid-template-rows:repeat(7, 14px);
      gap:4px;
      min-width:max-content;
      padding:12px 4px;
    }

    .heatmap-day {
      width:14px;
      height:14px;
      border-radius:4px;
      border:1px solid transparent;
      cursor:pointer;
      transition:transform .18s ease, box-shadow .18s ease;
    }

    .heatmap-day:hover {
      transform:scale(1.15);
      box-shadow:0 4px 10px rgba(180,107,93,.22);
    }

    .heatmap-day.today {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(180,107,93,.18);
    }

    .heatmap-0 { background:#f0e9e0; }
    .heatmap-1 { background:#ffe8d1; }
    .heatmap-2 { background:#ffcd9f; }
    .heatmap-3 { background:#ffad6e; }
    .heatmap-4 { background:#ff8a3d; }
    .heatmap-5 { background:#f46b1e; }
    .heatmap-6 { background:#d94f0f; }
    .heatmap-7 { background:#b46b5d; }

    body.dark .heatmap-0 { background:#2a2724; }
    body.dark .heatmap-1 { background:#3f2f28; }
    body.dark .heatmap-2 { background:#5c3f2f; }
    body.dark .heatmap-3 { background:#8a5a3f; }
    body.dark .heatmap-4 { background:#b46b5d; }
    body.dark .heatmap-5 { background:#d88a7d; }
    body.dark .heatmap-6 { background:#e8a48f; }
    body.dark .heatmap-7 { background:#f4c3b0; }

    .heatmap-legend {
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
      color:var(--muted);
      font-size:13px;
    }

    .heatmap-legend-scale {
      display:flex;
      gap:4px;
    }

    .heatmap-legend-scale div {
      width:14px;
      height:14px;
      border-radius:4px;
    }

    .month-row {
      display:grid;
      grid-auto-flow:column;
      grid-auto-columns:18px;
      gap:4px;
      min-width:max-content;
      color:var(--muted);
      font-size:12px;
      margin-bottom:8px;
      padding-left:4px;
    }

    @media (max-width:900px) {
      .layout {
        grid-template-columns:1fr;
      }

      .right {
        border-left:none;
        border-top:1px solid var(--line);
      }

      .stats {
        grid-template-columns:1fr;
      }

      .topbar {
        flex-direction:column;
        align-items:flex-start;
      }
    }

    /* ✅ 新增：移动端热力图视觉适配 */
    @media (max-width: 768px) {
      .heatmap-grid {
        grid-auto-columns: 16px;
        grid-template-rows: repeat(7, 16px);
        gap: 5px;
      }

      .heatmap-day {
        width: 16px;
        height: 16px;
      }

      .month-row {
        grid-auto-columns: 21px;
        gap: 5px;
        font-size: 11px;
      }

      .subpage-topbar {
        align-items: flex-start;
      }

      /* 任务输入区域移动端适配 */
      .task-input-desktop {
        display: none !important;
      }

      .task-add-mobile-btn {
        display: block !important;
      }

      /* 任务列表项移动端优化 */
      .item {
        padding: 12px;
        flex-wrap: wrap;
      }

      .task-header {
        flex-wrap: wrap;
      }

      .task-time {
        width: 100%;
        margin-left: 20px;
        margin-top: 4px;
      }

      .priority-badge {
        width: 10px;
        height: 10px;
      }

      /* 任务总时长卡片 */
      .task-total-time {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
    }

    /* 抽屉样式 */
    .drawer-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 9998;
      display: none;
      backdrop-filter: blur(4px);
    }

    .drawer-overlay.show {
      display: block;
      animation: fadeIn 0.3s ease;
    }

    .task-drawer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--card);
      border-radius: 24px 24px 0 0;
      padding: 24px;
      z-index: 9999;
      transform: translateY(100%);
      transition: transform 0.3s ease;
      box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.2);
      max-height: 80vh;
      overflow-y: auto;
    }

    .task-drawer.show {
      transform: translateY(0);
    }

    .drawer-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line);
    }

    .drawer-title {
      font-size: 18px;
      font-weight: 700;
    }

    .drawer-close {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 1px solid var(--line);
      background: var(--card);
      color: var(--text);
      font-size: 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .drawer-field {
      margin-bottom: 16px;
    }

    .drawer-label {
      display: block;
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 8px;
      font-weight: 500;
    }

    .drawer-input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--card);
      color: var(--text);
      font-size: 15px;
    }

    .drawer-priority-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .drawer-priority-btn {
      padding: 14px;
      border: 2px solid var(--line);
      border-radius: 14px;
      background: var(--card);
      color: var(--text);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: center;
    }

    .drawer-priority-btn.active-high {
      background: rgba(239, 68, 68, 0.1);
      border-color: rgba(239, 68, 68, 0.4);
    }

    .drawer-priority-btn.active-medium {
      background: rgba(245, 158, 11, 0.1);
      border-color: rgba(245, 158, 11, 0.4);
    }

    .drawer-priority-btn.active-low {
      background: rgba(156, 163, 175, 0.1);
      border-color: rgba(156, 163, 175, 0.3);
    }

    .task-add-mobile-btn {
      display: none;
      width: 100%;
      padding: 14px;
      margin-bottom: 12px;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  </style>
</head>
<body>
  <button class="btn primary hidden" id="exitImmersiveBtn" style="position: fixed; top: 30px; right: 30px; z-index: 1000; box-shadow: var(--shadow);">退出沉浸模式</button>

  <div class="undo-toast" id="undoToast">
    <span id="undoToastMsg"></span>
    <button id="undoBtn">撤销</button>
    <div class="undo-toast-bar" id="undoBar"></div>
  </div>

  <div id="mainPage" class="page">
    <div class="wrap">
      <div class="app">
        <div class="topbar">
          <div class="brand">
            <small>STUDY ROOM</small>
            <h1>稀奇小杰泥自习室</h1>
          </div>

          <div class="toolbar">
            <div class="chip" id="userChip">未登录</div>
            <button class="icon-btn" id="themeBtn" title="切换深浅色">☾</button>
            <button class="icon-btn" id="fullBtn" title="全屏">⛶</button>
            <button class="btn ghost hidden" id="logoutBtn">退出登录</button>
          </div>
        </div>

        <div class="layout">
          <section class="left">
            <div class="ok-banner">Focus space.</div>
            <div id="appStatus" class="app-status">正在连接服务器...</div>

            <div id="authView">
              <div class="hero-note">先登录，再开始你的专注。</div>

              <div class="auth-box card">
                <div class="tabs">
                  <button class="tab active" data-auth-tab="login">登录</button>
                  <button class="tab" data-auth-tab="signup">注册</button>
                </div>

                <div id="loginPane">
                  <div class="row" style="margin-bottom:10px">
                    <input id="loginEmail" type="email" placeholder="邮箱" />
                  </div>
                  <div class="row" style="margin-bottom:10px">
                    <input id="loginPassword" type="password" placeholder="密码" />
                  </div>
                  <button class="btn primary" id="loginBtn" style="width:100%">登录</button>
                  <div class="auth-note">第一次注册后，如果系统要求邮箱确认，请先去邮箱点击确认链接，再回来登录。</div>
                </div>

                <div id="signupPane" class="hidden">
                  <div class="row" style="margin-bottom:10px">
                    <input id="signupUsername" type="text" placeholder="用户名（用于排行榜显示）" />
                  </div>
                  <div class="row" style="margin-bottom:10px">
                    <input id="signupEmail" type="email" placeholder="邮箱" />
                  </div>
                  <div class="row" style="margin-bottom:10px">
                    <input id="signupPassword" type="password" placeholder="密码" />
                  </div>
                  <button class="btn primary" id="signupBtn" style="width:100%">注册</button>
                  <div class="auth-note">注册成功后，如果没有自动登录，请先确认邮箱，再回来登录。</div>
                </div>
              </div>
            </div>

            <div id="studyView" class="hidden">
              <div class="hero-note">No noise. Just focus.</div>

              <div class="card focus-card">
                <div class="mode" id="modeText">当前专注：120分钟</div>

                <div style="margin-top:14px; display:flex; gap:8px; justify-content:center; align-items:center;">
                  <span style="font-size:13px; color:var(--muted);">科目：</span>
                  <input id="customSubjectInput" type="text" placeholder="输入科目（如：数学）" style="width:140px;padding:8px 12px;font-size:13px;border-radius:12px;text-align:center;" />
                </div>

                <div class="controls" style="margin-top:10px">
                  <button class="btn" data-time="1500">25m</button>
                  <button class="btn" data-time="2700">45m</button>
                  <button class="btn" data-time="5400">90m</button>
                  <button class="btn time-btn-active" data-time="7200">120m</button>
                  <div style="display:flex;gap:6px;align-items:center;">
                    <input id="customMinInput" type="number" min="1" max="600" placeholder="自定义" style="width:80px;padding:10px 10px;font-size:13px;border-radius:14px;text-align:center;" />
                    <button class="btn" id="customTimeBtn">确定</button>
                  </div>
                </div>
                <div class="timer" id="timer" style="cursor: pointer;" title="点击切换正计时/倒计时">02:00:00</div>
                <div class="status" id="statusText">现在只做这一件事。</div>
                <div class="controls">
                  <button class="btn primary" id="startBtn">开始专注</button>
                  <button class="btn" id="pauseBtn">暂停</button>
                  <button class="btn" id="resetBtn">重置</button>
                  <button class="btn ghost" id="saveManualBtn">手动记 120 分钟</button>
                  <button class="btn ghost" id="immersiveBtn">开启沉浸</button>
                </div>
              </div>

              <div class="card" style="margin-top:16px">
                <div style="display:flex;justify-content:space-between;margin-bottom:8px; align-items:center;">
                  <span style="display:flex; align-items:center; gap:10px;">
                    今日进度
                    <button class="btn ghost" id="editGoalBtn" style="padding:4px 8px; font-size:12px; border:1px solid var(--line);">设定目标</button>
                  </span>
                  <span id="progressText" style="font-weight:bold;">0%</span>
                </div>

                <div style="width:100%;height:10px;background:#00000010;border-radius:999px">
                  <div id="progressBar" style="
                    height:100%;
                    width:0%;
                    background:var(--accent);
                    border-radius:999px;
                    transition: width 0.3s ease;
                  "></div>
                </div>
              </div>

              <div class="stats">
                <div class="stat">
                  <div class="k">今日专注</div>
                  <div class="v" id="todayMinutes">0m</div>
                </div>
                <div class="stat">
                  <div class="k">累计时长</div>
                  <div class="v" id="totalHours">0h</div>
                </div>
                <div class="stat">
                  <div class="k">完成轮次</div>
                  <div class="v" id="sessionCount">0</div>
                </div>
              </div>

              <div class="subject-stats-card">
                <div class="subject-stats-header">
                  <h3>科目统计</h3>
                  <div class="subject-stats-tabs">
                    <button class="subject-stats-tab active" data-range="today">今日</button>
                    <button class="subject-stats-tab" data-range="week">近7天</button>
                    <button class="subject-stats-tab" data-range="month">近30天</button>
                    <button class="subject-stats-tab" data-range="all">全部</button>
                  </div>
                </div>
                <div id="subjectStatsList"></div>
              </div>

              <div class="card" style="margin-top:16px;">
                <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                  <div>
                    <div style="font-size:18px;font-weight:700;">专注热力图</div>
                    <div class="muted" style="font-size:13px;margin-top:4px;">查看您的专注分布与学习轨迹</div>
                  </div>
                  <button class="btn primary" id="openHeatmapBtn">查看专注轨迹</button>
                </div>
              </div>

              <div class="quote">先静下来，再开始。</div>
            </div>
          </section>

          <aside class="right">
            <div id="checkinArea" class="hidden">
              <div class="card checkin-card">
                <div class="checkin-header">
                  <div class="checkin-date" id="displayDate"></div>
                  <div id="checkinStatus" class="muted" style="font-size:12px;">未签到</div>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <div class="checkin-stats">已连续签到 <b id="streakDays">0</b> 天</div>
                  <button class="btn primary" id="checkinBtn">今日签到</button>
                </div>
              </div>
            </div>

            <div class="tabs">
              <button class="tab active" data-side-tab="tasks">任务清单</button>
              <button class="tab" data-side-tab="leaderboard">排行榜</button>
              <button class="tab" data-side-tab="history">专注历史</button>
            </div>

            <div id="tasksPane">
              <div class="section-title" style="margin-bottom: 8px;">
                <div>
                  <h2>任务清单</h2>
                  <p id="taskStatsText" style="font-weight: 500; color: var(--accent);">别列太多，先完成最重要的。</p>
                </div>
              </div>
              
              <div class="row" style="margin-bottom:14px; align-items:center;">
                <input type="date" id="taskDatePicker" style="flex:1; padding:8px 12px; font-size:13px; border-radius:12px;" />
                <button class="btn ghost" id="goYesterdayBtn" style="padding:8px 12px; font-size:13px;">昨天</button>
                <button class="btn ghost" id="goTodayBtn" style="padding:8px 12px; font-size:13px;">今天</button>
              </div>

              <!-- 移动端：添加任务按钮 -->
              <button class="btn primary task-add-mobile-btn" id="openDrawerBtn">+ 添加新任务</button>

              <!-- 桌面端：输入框 -->
              <div class="row task-input-desktop" style="margin-bottom:12px">
                <input id="taskInput" type="text" placeholder="添加新任务..." style="flex:2;" />
                <input id="taskTimeInput" type="number" placeholder="时长(分钟)" min="1" max="600" style="width:110px; padding:8px 12px;" />
                <select id="taskPrioritySelect" style="width:120px; padding:8px 12px; border:1px solid var(--line); background:var(--card); color:var(--text); border-radius:12px; font-weight:500;">
                  <option value="high" style="color:#ef4444;">🔴 优先做</option>
                  <option value="medium" selected style="color:#f59e0b;">🟡 重点做</option>
                  <option value="low" style="color:#9ca3af;">⚪ 有时间做</option>
                </select>
                <button class="btn primary" id="addTaskBtn">添加</button>
              </div>

              <div id="taskTotalTime" class="task-total-time" style="display:none;">
                <span id="taskTotalText">今日计划：0分钟</span>
                <span id="taskWarning" class="warning" style="display:none;">⚠️ 任务过多，建议精简</span>
              </div>

              <div class="list" id="taskList"></div>
            </div>

            <div id="leaderboardPane" class="hidden">
              <div class="section-title">
                <div>
                  <h2>排行榜</h2>
                  <p>看看大家今天的专注表现。</p>
                </div>
                <button class="btn" id="refreshLeaderboardBtn">刷新</button>
              </div>

              <div class="tabs" style="margin-bottom:12px;">
                <button class="tab active" id="dailyRankTab" style="padding: 6px 12px; font-size: 13px;">今日榜</button>
                <button class="tab" id="totalRankTab" style="padding: 6px 12px; font-size: 13px;">总榜</button>
              </div>

              <div class="list" id="leaderList"></div>
            </div>

            <div id="historyPane" class="hidden">
              <div class="section-title">
                <div>
                  <h2>我的历史</h2>
                  <p>只显示当前账号的学习记录。</p>
                </div>
                <button class="btn" id="refreshHistoryBtn">刷新</button>
              </div>

              <div class="list" id="historyList"></div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>

  <div id="heatmapPage" class="page hidden-page">
    <div class="heatmap-page-wrap">
      <div class="app">
        <div class="topbar">
          <div class="brand">
            <small>STUDY ROOM</small>
            <h1>专注热力图</h1>
          </div>
          <div class="toolbar">
            <div class="chip" id="heatmapUserChip">未登录</div>
            <button class="btn ghost" id="backToMainBtn">返回主页</button>
          </div>
        </div>

        <div class="left" style="padding:24px;">
          <div class="card">
            <div class="subpage-topbar">
              <div>
                <h2 id="heatmapTitle" style="margin:0 0 6px 0;">过去 30 天专注分布</h2>
                <p id="heatmapSubtitle" class="muted" style="margin:0;">颜色越深，代表当天专注时间越长</p>
              </div>
              <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
                <select id="subjectFilter" style="padding:6px 10px;font-size:12px;border-radius:10px;border:1px solid var(--line);background:var(--card);color:var(--text);">
                  <option value="全部">全部科目</option>
                </select>
                <div class="tabs" style="margin-bottom:0;">
                  <button class="tab active" id="heatmap30Btn" style="padding: 6px 10px; font-size: 12px;">近 30 天</button>
                  <button class="tab" id="heatmap365Btn" style="padding: 6px 10px; font-size: 12px;">全年</button>
                </div>
                <button class="btn" id="refreshHeatmapBtn" style="padding: 6px 10px; font-size: 12px;">刷新</button>
              </div>
            </div>

            <div id="monthRow" class="month-row"></div>

            <div class="heatmap-grid-wrap">
              <div id="heatmapGrid" class="heatmap-grid"></div>
            </div>

            <div class="heatmap-legend">
              <span>少</span>
              <div class="heatmap-legend-scale">
                <div class="heatmap-0"></div>
                <div class="heatmap-2"></div>
                <div class="heatmap-4"></div>
                <div class="heatmap-6"></div>
                <div class="heatmap-7"></div>
              </div>
              <span>多</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const supabase = createClient(
      "https://smrhzgabbeqgamdafsrn.supabase.co",
      "sb_publishable_iBTzbd8FJRXhA_if49EB4g_URc3HoYF"
    );

    const THEME_KEY = "study_room_theme_final_v2";
    const GOAL_KEY = "study_room_daily_goal_v1";

    let currentUser = null;
    let timer = null;
    let remaining = 7200;
    let selectedDuration = 7200;
    let startedAt = null;
    let currentTodayMinutes = 0;
    let selectedTaskDate = null;
    let currentRankType = "daily";
    let currentTasks = [];
    let currentHeatmapRange = 30;
    let selectedSubject = "";
    let currentSubjectFilter = "全部";
    let timerMode = "countdown"; // "countdown" 或 "countup"

    let appReady = false;
    let authLoading = false;
    let leaderboardLoading = false;
    let historyLoading = false;
    let statsLoading = false;

    const $ = (id) => document.getElementById(id);

    let undoTimer = null;

    function showUndoToast(minutes) {
      if (undoTimer) { clearTimeout(undoTimer); hideUndoToast(); }
      const toast = document.getElementById("undoToast");
      const msg = document.getElementById("undoToastMsg");
      const bar = document.getElementById("undoBar");
      const undoBtn = document.getElementById("undoBtn");

      msg.textContent = `已记录 ${minutes} 分钟`;
      toast.classList.add("show");

      // 重置动画
      bar.style.animation = "none";
      bar.offsetHeight; // reflow
      bar.style.animation = "";

      let cancelled = false;

      undoBtn.onclick = () => {
        cancelled = true;
        clearTimeout(undoTimer);
        hideUndoToast();
      };

      undoTimer = setTimeout(async () => {
        if (!cancelled) await saveStudySession(minutes);
        hideUndoToast();
      }, 5000);
    }

    function hideUndoToast() {
      const toast = document.getElementById("undoToast");
      toast.classList.remove("show");
      undoTimer = null;
    }

    const el = {
      userChip:$("userChip"),
      themeBtn:$("themeBtn"),
      fullBtn:$("fullBtn"),
      logoutBtn:$("logoutBtn"),
      appStatus:$("appStatus"),

      authView:$("authView"),
      studyView:$("studyView"),

      loginEmail:$("loginEmail"),
      loginPassword:$("loginPassword"),
      loginBtn:$("loginBtn"),

      signupUsername:$("signupUsername"),
      signupEmail:$("signupEmail"),
      signupPassword:$("signupPassword"),
      signupBtn:$("signupBtn"),

      timer:$("timer"),
      statusText:$("statusText"),
      startBtn:$("startBtn"),
      pauseBtn:$("pauseBtn"),
      resetBtn:$("resetBtn"),
      saveManualBtn:$("saveManualBtn"),
      immersiveBtn:$("immersiveBtn"),
      exitImmersiveBtn:$("exitImmersiveBtn"),

      todayMinutes:$("todayMinutes"),
      totalHours:$("totalHours"),
      sessionCount:$("sessionCount"),
      editGoalBtn:$("editGoalBtn"),

      taskDatePicker:$("taskDatePicker"),
      goYesterdayBtn:$("goYesterdayBtn"),
      goTodayBtn:$("goTodayBtn"),
      taskInput:$("taskInput"),
      addTaskBtn:$("addTaskBtn"),
      taskList:$("taskList"),
      taskStatsText:$("taskStatsText"),
      taskTotalTime:$("taskTotalTime"),
      taskTotalText:$("taskTotalText"),
      taskWarning:$("taskWarning"),

      mobileAddTaskBtn:$("openDrawerBtn"),
      taskDrawer:$("taskDrawer"),
      drawerOverlay:$("drawerOverlay"),
      closeDrawerBtn:$("closeDrawerBtn"),
      drawerTaskInput:$("drawerTaskInput"),
      drawerDurationInput:$("drawerTimeInput"),
      drawerAddBtn:$("drawerAddBtn"),

      dailyRankTab:$("dailyRankTab"),
      totalRankTab:$("totalRankTab"),
      leaderList:$("leaderList"),
      refreshLeaderboardBtn:$("refreshLeaderboardBtn"),

      historyList:$("historyList"),
      refreshHistoryBtn:$("refreshHistoryBtn"),

      checkinArea:$("checkinArea"),
      displayDate:$("displayDate"),
      checkinStatus:$("checkinStatus"),
      streakDays:$("streakDays"),
      checkinBtn:$("checkinBtn"),

      openHeatmapBtn:$("openHeatmapBtn"),
      backToMainBtn:$("backToMainBtn"),
      refreshHeatmapBtn:$("refreshHeatmapBtn"),
      heatmapGrid:$("heatmapGrid"),
      heatmapSubtitle:$("heatmapSubtitle"),
      monthRow:$("monthRow"),
      mainPage:$("mainPage"),
      heatmapPage:$("heatmapPage"),
      heatmapUserChip:$("heatmapUserChip"),

      heatmapTitle:$("heatmapTitle"),
      heatmap30Btn:$("heatmap30Btn"),
      heatmap365Btn:$("heatmap365Btn"),
    };

    const loadJSON = (k, f) => {
      try {
        const raw = localStorage.getItem(k);
        return raw ? JSON.parse(raw) : f;
      } catch {
        return f;
      }
    };
    const saveJSON = (k, v) => localStorage.setItem(k, JSON.stringify(v));
    const showMessage = (m) => alert(m);

    let dailyGoal = loadJSON(GOAL_KEY, 240); 

    const esc = (s) => String(s).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#39;");

    const formatTime = (sec) => {
      const h = Math.floor(sec / 3600);
      const m = Math.floor((sec % 3600) / 60);
      const s = sec % 60;
      return [h,m,s].map(v => String(v).padStart(2, "0")).join(":");
    };

    const formatMinutes = (min) => {
      if (min < 60) return `${min}m`;
      const h = Math.floor(min / 60);
      const m = min % 60;
      return m ? `${h}h ${m}m` : `${h}h`;
    };

    const getLocalDateISO = (date = new Date()) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    };

    function updateProgress(today) {
      const validGoal = dailyGoal > 0 ? dailyGoal : 240; 
      const percent = (today / validGoal) * 100;
      const display = Math.min(100, percent);
      document.getElementById("progressBar").style.width = display + "%";
      document.getElementById("progressText").innerHTML = 
        `${Math.floor(percent)}% <span style="font-size:12px;color:var(--muted);font-weight:normal;margin-left:4px;">/ ${formatMinutes(validGoal)}</span>`;
    }

    let heatmapDataMap = new Map();

    function getHeatClass(minutes) {
      if (minutes === 0) return "heatmap-0";
      if (minutes <= 30) return "heatmap-1";
      if (minutes <= 60) return "heatmap-2";
      if (minutes <= 120) return "heatmap-3";
      if (minutes <= 180) return "heatmap-4";
      if (minutes <= 240) return "heatmap-5";
      if (minutes <= 360) return "heatmap-6";
      return "heatmap-7";
    }

    function showMainPage() {
      el.mainPage.classList.remove("hidden-page");
      el.heatmapPage.classList.add("hidden-page");
      window.scrollTo(0, 0);
    }

    function showHeatmapPage() {
      el.mainPage.classList.add("hidden-page");
      el.heatmapPage.classList.remove("hidden-page");
      window.scrollTo(0, 0);
    }

    async function loadHeatmapData() {
      if (!currentUser) {
        heatmapDataMap.clear();
        return;
      }

      try {
        const startDate = new Date();
        startDate.setDate(startDate.getDate() - Math.max(currentHeatmapRange + 14, 45));

        let query = supabase
          .from("study_sessions")
          .select("duration_minutes, created_at, subject")
          .eq("user_id", currentUser.id)
          .gte("created_at", startDate.toISOString());

        if (currentSubjectFilter !== "全部") {
          query = query.eq("subject", currentSubjectFilter);
        }

        const { data, error } = await query;
        if (error) throw error;

        heatmapDataMap.clear();

        (data || []).forEach(session => {
          const dateStr = getLocalDateISO(new Date(session.created_at));
          const mins = Number(session.duration_minutes || 0);
          heatmapDataMap.set(dateStr, (heatmapDataMap.get(dateStr) || 0) + mins);
        });
      } catch (err) {
        console.error("loadHeatmapData error:", err);
      }
    }

    async function loadSubjectList() {
      if (!currentUser) return;
      try {
        const { data, error } = await supabase
          .from("study_sessions")
          .select("subject")
          .eq("user_id", currentUser.id)
          .not("subject", "is", null);

        if (error) throw error;

        const subjects = [...new Set((data || []).map(s => s.subject).filter(s => s && s !== "未分类"))];
        const filterEl = document.getElementById("subjectFilter");
        if (filterEl) {
          filterEl.innerHTML = '<option value="全部">全部科目</option>';
          subjects.forEach(subject => {
            const option = document.createElement("option");
            option.value = subject;
            option.textContent = subject;
            filterEl.appendChild(option);
          });
        }
      } catch (err) {
        console.error("loadSubjectList error:", err);
      }
    }

    async function renderHeatmap() {
      if (!el.heatmapGrid) return;

      el.heatmapGrid.innerHTML = `<div class="muted" style="grid-column:1/-1;padding:20px 0;">加载热力图中...</div>`;
      if (el.monthRow) el.monthRow.innerHTML = "";

      await loadHeatmapData();

      const today = new Date();
      const endDate = new Date(today);
      const startDate = new Date(today);
      
      startDate.setDate(startDate.getDate() - (currentHeatmapRange - 1));

      const alignedStart = new Date(startDate);
      alignedStart.setDate(alignedStart.getDate() - alignedStart.getDay());

      const alignedEnd = new Date(endDate);
      alignedEnd.setDate(alignedEnd.getDate() + (6 - alignedEnd.getDay()));

      const gridFrag = document.createDocumentFragment();
      const monthFrag = document.createDocumentFragment();

      let totalMinutes = 0;
      let current = new Date(alignedStart);
      let weekIndex = 0;
      let lastMonth = -1;

      while (current <= alignedEnd) {
        const weekStart = new Date(current);

        if (weekStart <= endDate) {
          const month = weekStart.getMonth();
          const monthCell = document.createElement("div");
          monthCell.textContent = month !== lastMonth ? `${month + 1}月` : "";
          monthCell.style.minHeight = "14px";
          monthFrag.appendChild(monthCell);
          lastMonth = month;
        }

        for (let day = 0; day < 7; day++) {
          const cellDate = new Date(weekStart);
          cellDate.setDate(weekStart.getDate() + day);

          const dateStr = getLocalDateISO(cellDate);
          const minutes = heatmapDataMap.get(dateStr) || 0;

          if (cellDate >= startDate && cellDate <= endDate) {
            totalMinutes += minutes;
          }

          const dayEl = document.createElement("div");
          dayEl.className = `heatmap-day ${getHeatClass(minutes)} ${dateStr === getLocalDateISO(today) ? "today" : ""}`;
          dayEl.title = `${dateStr}｜专注 ${minutes} 分钟`;

          if (cellDate < startDate || cellDate > endDate) {
            dayEl.style.opacity = "0.18";
          } else {
            dayEl.addEventListener("click", async () => {
              showMainPage();
              selectedTaskDate = dateStr;
              el.taskDatePicker.value = dateStr;
              document.querySelector('[data-side-tab="tasks"]').click();
              await loadTasksByDate(dateStr);
            });
          }

          gridFrag.appendChild(dayEl);
        }

        current.setDate(current.getDate() + 7);
        weekIndex++;
      }

      el.heatmapGrid.innerHTML = "";
      el.heatmapGrid.appendChild(gridFrag);

      if (el.monthRow) {
        el.monthRow.innerHTML = "";
        el.monthRow.appendChild(monthFrag);
      }

      if (el.heatmapTitle) {
        el.heatmapTitle.textContent = `过去 ${currentHeatmapRange} 天专注分布`;
      }

      if (el.heatmapSubtitle) {
        const subjectText = currentSubjectFilter === "全部" ? "" : `（${currentSubjectFilter}）`;
        if (totalMinutes === 0) {
          el.heatmapSubtitle.innerHTML = `过去 ${currentHeatmapRange} 天${subjectText} · 暂无专注记录`;
        } else {
          el.heatmapSubtitle.innerHTML = `过去 ${currentHeatmapRange} 天${subjectText} · 共专注 <b>${Math.floor(totalMinutes / 60)}</b> 小时`;
        }
      }
    }

    async function loadTasksByDate(dateStr) {
      if (!currentUser) {
        currentTasks = [];
        renderTasks();
        return;
      }
      try {
        const { data, error } = await supabase
          .from("tasks")
          .select("id, text, done, task_date, created_at, duration_minutes, priority")
          .eq("user_id", currentUser.id)
          .eq("task_date", dateStr)
          .order("created_at", { ascending: false });

        if (error) throw error;
        currentTasks = data || [];
        renderTasks();
      } catch (err) {
        console.error("loadTasksByDate error:", err);
        currentTasks = [];
        el.taskList.innerHTML = `<div class="item"><div class="main danger">任务加载失败，请稍后重试。</div></div>`;
      }
    }

    async function addTaskToSupabase(text, dateStr, durationMinutes, priority) {
      if (!currentUser) {
        showMessage("请先登录。");
        return;
      }
      if (!durationMinutes || durationMinutes <= 0) {
        showMessage("请输入任务时长（分钟）。");
        return;
      }
      try {
        const { error } = await supabase
          .from("tasks")
          .insert({
            user_id: currentUser.id,
            task_date: dateStr,
            text: text,
            done: false,
            duration_minutes: durationMinutes,
            priority: priority || "medium"
          });

        if (error) throw error;
        await loadTasksByDate(dateStr);
      } catch (err) {
        console.error("addTaskToSupabase error:", err);
        showMessage("添加任务失败，请稍后重试。");
      }
    }

    async function toggleTaskDone(taskId, done) {
      try {
        const { error } = await supabase
          .from("tasks")
          .update({ done })
          .eq("id", taskId)
          .eq("user_id", currentUser.id);

        if (error) throw error;
        await loadTasksByDate(selectedTaskDate);
      } catch (err) {
        console.error("toggleTaskDone error:", err);
        showMessage("更新任务失败，请稍后重试。");
      }
    }

    async function deleteTaskFromSupabase(taskId) {
      try {
        const { error } = await supabase
          .from("tasks")
          .delete()
          .eq("id", taskId)
          .eq("user_id", currentUser.id);

        if (error) throw error;
        await loadTasksByDate(selectedTaskDate);
      } catch (err) {
        console.error("deleteTaskFromSupabase error:", err);
        showMessage("删除任务失败，请稍后重试。");
      }
    }

    async function changeTaskDate(days) {
      const d = new Date(selectedTaskDate + "T00:00:00");
      d.setDate(d.getDate() + days);
      selectedTaskDate = getLocalDateISO(d);
      el.taskDatePicker.value = selectedTaskDate;
      await loadTasksByDate(selectedTaskDate);
    }

    function renderTasks() {
      const tasks = currentTasks || [];
      el.taskList.innerHTML = "";
      const total = tasks.length;
      const done = tasks.filter(t => t.done).length;
      const dateObj = new Date(selectedTaskDate + "T00:00:00");
      const displayDate = `${dateObj.getMonth() + 1}月${dateObj.getDate()}日`;

      if (total === 0) {
        el.taskStatsText.textContent = `${displayDate} 暂无任务`;
        el.taskStatsText.style.color = "var(--muted)";
        el.taskList.innerHTML = '<div class="item"><div class="main muted">这一天还没有任务，添一条试试。</div></div>';
        el.taskTotalTime.style.display = "none";
        return;
      }

      const pct = Math.round((done / total) * 100);
      el.taskStatsText.textContent = `${displayDate} · 已完成 ${done} / ${total} 项 (${pct}%)`;
      el.taskStatsText.style.color = pct === 100 ? "var(--ok)" : "var(--accent)";

      // 计算今日总时长
      const totalMinutes = tasks.reduce((sum, t) => sum + (t.duration_minutes || 0), 0);
      const hours = Math.floor(totalMinutes / 60);
      const mins = totalMinutes % 60;
      let timeText = "今日计划：";
      if (hours > 0) timeText += `${hours}小时`;
      if (mins > 0) timeText += `${mins}分钟`;
      if (totalMinutes === 0) timeText += "0分钟";

      el.taskTotalText.textContent = timeText;
      el.taskTotalTime.style.display = "flex";

      // 超过6小时提示
      if (totalMinutes > 360) {
        el.taskWarning.style.display = "block";
        el.taskTotalTime.classList.add("overload");
      } else {
        el.taskWarning.style.display = "none";
        el.taskTotalTime.classList.remove("overload");
      }

      // 排序：优先级（高→中→低）+ 完成状态（未完成在前）+ 创建时间
      const priorityOrder = { high: 1, medium: 2, low: 3 };
      const sortedTasks = [...tasks].sort((a, b) => {
        if (a.done !== b.done) return a.done ? 1 : -1;
        const aPriority = priorityOrder[a.priority || "medium"];
        const bPriority = priorityOrder[b.priority || "medium"];
        if (aPriority !== bPriority) return aPriority - bPriority;
        return new Date(b.created_at) - new Date(a.created_at);
      });

      sortedTasks.forEach((task) => {
        const item = document.createElement("div");
        const priorityClass = task.priority || "medium";
        item.className = "item task-priority-" + priorityClass + (task.done ? " task-done" : "");

        const priorityBadgeClass = `priority-${priorityClass}`;
        const durationText = task.duration_minutes ? `${task.duration_minutes}分钟` : "";

        item.innerHTML = `
          <input type="checkbox" ${task.done ? "checked" : ""}>
          <div class="main">
            <div class="task-header">
              <span class="priority-badge ${priorityBadgeClass}"></span>
              <span class="task-text">${esc(task.text)}</span>
              <span class="task-time">${durationText}</span>
            </div>
          </div>
          <button class="btn ghost">删除</button>
        `;
        const checkbox = item.querySelector("input");
        const delBtn = item.querySelector("button");
        
        checkbox.addEventListener("change", () => {
          toggleTaskDone(task.id, checkbox.checked);
        });
        
        delBtn.addEventListener("click", () => {
          deleteTaskFromSupabase(task.id);
        });
        
        el.taskList.appendChild(item);
      });
    }

    async function loadCheckinInfo() {
      if (!currentUser) return;
      const todayStr = new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
      el.displayDate.textContent = todayStr;
      try {
        const { data, error } = await supabase.from("profiles").select("last_checkin_date, consecutive_days").eq("id", currentUser.id).single();
        if (error) throw error;
        const lastDate = data.last_checkin_date;
        const streak = data.consecutive_days || 0;
        const todayISO = getLocalDateISO();
        el.streakDays.textContent = streak;
        if (lastDate === todayISO) {
          el.checkinStatus.textContent = "已签到"; el.checkinStatus.classList.add("ok"); el.checkinBtn.textContent = "今日已完成"; el.checkinBtn.disabled = true; el.checkinBtn.classList.add("disabled");
        } else {
          el.checkinStatus.textContent = "未签到"; el.checkinStatus.classList.remove("ok"); el.checkinBtn.textContent = "今日签到"; el.checkinBtn.disabled = false; el.checkinBtn.classList.remove("disabled");
        }
      } catch (err) { console.error("加载签到信息失败:", err); }
    }

    async function handleCheckin() {
      if (!currentUser || authLoading) return;
      if (currentTodayMinutes < 30) {
        showMessage(`今日专注（${currentTodayMinutes}m）未达 30 分钟门槛，无法签到。先去完成一个番茄钟吧！`);
        return;
      }
      authLoading = true;
      setButtonLoading(el.checkinBtn, "签到中...", true);
      try {
        const todayISO = getLocalDateISO();
        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);
        const yesterdayISO = getLocalDateISO(yesterday);
        const { data: profile } = await supabase.from("profiles").select("last_checkin_date, consecutive_days").eq("id", currentUser.id).single();
        let newStreak = 1;
        if (profile.last_checkin_date === yesterdayISO) {
          newStreak = (profile.consecutive_days || 0) + 1;
        } else if (profile.last_checkin_date === todayISO) {
          showMessage("今天已经签到过啦！"); return;
        } else {
          if (profile.consecutive_days > 1) showMessage("很遗憾，昨天断签了。今天的专注是从头再来的第 1 天 🔁");
        }
        const { error } = await supabase.from("profiles").update({ last_checkin_date: todayISO, consecutive_days: newStreak }).eq("id", currentUser.id);
        if (error) throw error;
        if (newStreak > 1) { showMessage(`签到成功！稳扎稳打，已连续专注 ${newStreak} 天 🔥`); } else { showMessage("签到成功！今天是新的开始 ✅"); }
        await loadCheckinInfo();
      } catch (err) { console.error("签到失败:", err); showMessage("签到失败，请稍后重试。"); } finally { authLoading = false; setButtonLoading(el.checkinBtn, "", false); }
    }

    function setAppStatus(text, type = "") {
      if (!el.appStatus) return;
      el.appStatus.textContent = text || "";
      el.appStatus.classList.remove("error", "ok");
      if (type) el.appStatus.classList.add(type);
      if (!text) el.appStatus.classList.add("hidden"); else el.appStatus.classList.remove("hidden");
    }

    function setButtonLoading(button, loadingText, isLoading) {
      if (!button) return;
      if (!button.dataset.originalText) button.dataset.originalText = button.textContent;
      if (isLoading) { button.textContent = loadingText; button.disabled = true; button.classList.add("loading"); } else { button.textContent = button.dataset.originalText; button.disabled = false; button.classList.remove("loading"); }
    }

    function setInteractiveState(enabled) {
      const ids = ["loginBtn", "signupBtn", "startBtn", "pauseBtn", "resetBtn", "saveManualBtn", "refreshLeaderboardBtn", "refreshHistoryBtn", "addTaskBtn", "editGoalBtn", "checkinBtn"];
      ids.forEach((id) => { const btn = document.getElementById(id); if (!btn) return; btn.disabled = !enabled; btn.classList.toggle("disabled", !enabled); });
    }

    function updateTimer() {
      if (timerMode === "countdown") {
        el.timer.textContent = formatTime(remaining);
      } else {
        // 正计时模式：显示已用时间
        const elapsed = selectedDuration - remaining;
        el.timer.textContent = formatTime(elapsed);
      }
    }

    function updateAuthUI() {
      if (currentUser) {
        el.userChip.textContent = currentUser.email || "已登录";
        if (el.heatmapUserChip) el.heatmapUserChip.textContent = currentUser.email || "已登录";
        el.authView.classList.add("hidden");
        el.studyView.classList.remove("hidden");
        el.logoutBtn.classList.remove("hidden");
        el.checkinArea.classList.remove("hidden");
        loadSubjectStats("today");
      } else {
        el.userChip.textContent = "未登录";
        if (el.heatmapUserChip) el.heatmapUserChip.textContent = "未登录";
        el.authView.classList.remove("hidden");
        el.studyView.classList.add("hidden");
        el.logoutBtn.classList.add("hidden");
        el.checkinArea.classList.add("hidden");

        currentTasks = [];
        renderTasks();

        heatmapDataMap.clear();
        if (el.heatmapGrid) el.heatmapGrid.innerHTML = "";
        if (el.monthRow) el.monthRow.innerHTML = "";
        if (el.heatmapSubtitle) {
          el.heatmapSubtitle.textContent = "颜色越深，代表当天专注时间越长";
        }

        showMainPage();
      }
    }

    async function ensureProfile() {
      if (!currentUser) return;
      try {
        const fallbackUsername = (currentUser.user_metadata?.username || currentUser.email?.split("@")[0] || "学习者").slice(0, 30);
        const { data, error } = await supabase.from("profiles").select("id, username").eq("id", currentUser.id).maybeSingle();
        if (!data) { await supabase.from("profiles").upsert({ id: currentUser.id, username: fallbackUsername }); } else if (!data.username) { await supabase.from("profiles").upsert({ id: currentUser.id, username: fallbackUsername }); }
      } catch (err) { console.error("ensureProfile error:", err); }
    }

    async function signup() {
      if (!appReady || authLoading) return;
      const username = el.signupUsername.value.trim(); const email = el.signupEmail.value.trim(); const password = el.signupPassword.value.trim();
      if (!username || !email || !password) { showMessage("请填完整信息。"); return; }
      authLoading = true; setButtonLoading(el.signupBtn, "注册中...", true);
      try {
        const { data, error } = await supabase.auth.signUp({ email, password, options: { data: { username } } });
        if (error) throw error;
        if (data.user) { await supabase.from("profiles").upsert({ id: data.user.id, username }); }
        showMessage("注册成功。请去邮箱确认。");
      } catch (err) { showMessage("注册失败：" + err.message); } finally { authLoading = false; setButtonLoading(el.signupBtn, "", false); }
    }

    async function login() {
      if (!appReady || authLoading) return;
      const email = el.loginEmail.value.trim(); 
      const password = el.loginPassword.value.trim();
      
      if (!email || !password) { 
        showMessage("请填写邮箱和密码。"); 
        return; 
      }
      
      authLoading = true; 
      setButtonLoading(el.loginBtn, "登录中...", true);
      
      try {
        const { data, error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) throw error;
        
        currentUser = data.user || null;
        updateAuthUI();
      } catch (err) { 
        console.error("login error:", err);
        showMessage("登录失败：" + err.message); 
      } finally { 
        authLoading = false; 
        setButtonLoading(el.loginBtn, "", false); 
      }
    }

    async function logout() { await supabase.auth.signOut(); }

    async function saveStudySession(minutes = 120) {
      if (!currentUser) return;
      try {
        const subjectInput = document.getElementById("customSubjectInput");
        const subject = subjectInput ? subjectInput.value.trim() || "未分类" : "未分类";

        const payload = {
          user_id: currentUser.id,
          duration_minutes: minutes,
          subject: subject,
          started_at: startedAt ? new Date(startedAt).toISOString() : null,
          ended_at: new Date().toISOString()
        };
        const { error } = await supabase.from("study_sessions").insert(payload);
        if (error) throw error;
        showMessage(`已记录 ${minutes} 分钟学习时间${subject !== "未分类" ? `（${subject}）` : ""}。`);
        await loadMyStats(); await loadHistory(); await loadLeaderboard();

        if (!el.heatmapPage.classList.contains("hidden-page")) {
          await renderHeatmap();
        }
      } catch (err) { showMessage("记录失败：" + err.message); }
    }

    async function loadMyStats() {
      if (!currentUser || statsLoading) return;
      statsLoading = true;
      try {
        const { data, error } = await supabase.from("study_sessions").select("duration_minutes, created_at").eq("user_id", currentUser.id);
        if (error) throw error;
        const total = data.reduce((s, x) => s + Number(x.duration_minutes || 0), 0);
        const todayISO = getLocalDateISO();
        const today = data.filter(x => x.created_at && getLocalDateISO(new Date(x.created_at)) === todayISO).reduce((s, x) => s + Number(x.duration_minutes || 0), 0);
        currentTodayMinutes = today;

        // 使用动画更新数字
        animateNumber(el.todayMinutes, today);
        animateNumber(el.totalHours, total);
        animateNumber(el.sessionCount, data.length);
        updateProgress(today);
      } catch (err) { console.error(err); } finally { statsLoading = false; }
    }

    let currentSubjectRange = "today";

    // 数字跳动动画
    function animateNumber(element, target, duration = 600) {
      const start = parseInt(element.textContent) || 0;
      const startTime = performance.now();

      function update(currentTime) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // easeOut cubic
        const current = Math.floor(start + (target - start) * eased);
        element.textContent = current;

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element.textContent = target;
        }
      }

      requestAnimationFrame(update);
    }

    async function loadSubjectStats(range = "today") {
      if (!currentUser) return;
      currentSubjectRange = range;

      try {
        const now = new Date();
        let startDate = null;

        if (range === "today") {
          startDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        } else if (range === "week") {
          startDate = new Date(now);
          startDate.setDate(startDate.getDate() - 7);
        } else if (range === "month") {
          startDate = new Date(now);
          startDate.setDate(startDate.getDate() - 30);
        }

        let query = supabase
          .from("study_sessions")
          .select("duration_minutes, subject")
          .eq("user_id", currentUser.id);

        if (startDate) {
          query = query.gte("created_at", startDate.toISOString());
        }

        const { data, error } = await query;
        if (error) throw error;

        const subjectMap = new Map();
        let totalMinutes = 0;

        (data || []).forEach(session => {
          const subject = session.subject || "未分类";
          const mins = Number(session.duration_minutes || 0);
          subjectMap.set(subject, (subjectMap.get(subject) || 0) + mins);
          totalMinutes += mins;
        });

        const subjects = Array.from(subjectMap.entries())
          .map(([name, minutes]) => ({ name, minutes, percent: totalMinutes > 0 ? (minutes / totalMinutes) * 100 : 0 }))
          .sort((a, b) => b.minutes - a.minutes);

        renderSubjectStats(subjects);
      } catch (err) {
        console.error("loadSubjectStats error:", err);
      }
    }

    function renderSubjectStats(subjects) {
      const container = document.getElementById("subjectStatsList");
      if (!container) return;

      if (!subjects || subjects.length === 0) {
        container.innerHTML = '<div class="subject-empty">暂无科目数据</div>';
        return;
      }

      container.innerHTML = "";
      subjects.forEach(subject => {
        const item = document.createElement("div");
        item.className = "subject-item";
        item.innerHTML = `
          <div class="subject-name">${esc(subject.name)}</div>
          <div class="subject-bar-container">
            <div class="subject-bar" style="width:0%"></div>
          </div>
          <div class="subject-duration">${formatMinutes(subject.minutes)}</div>
        `;
        container.appendChild(item);

        // 触发动画
        setTimeout(() => {
          const bar = item.querySelector('.subject-bar');
          bar.style.width = subject.percent + '%';
        }, 50);
      });
    }

    async function loadLeaderboard() {
      if (leaderboardLoading) return;
      leaderboardLoading = true; setButtonLoading(el.refreshLeaderboardBtn, "刷新中...", true);
      try {
        const tableName = currentRankType === "daily" ? "daily_leaderboard" : "leaderboard";
        const { data, error } = await supabase.from(tableName).select("*").limit(100);
        el.leaderList.innerHTML = "";
        if (error) throw error;
        if (!data || !data.length) {
          el.leaderList.innerHTML = `<div class="item"><div class="main muted">${currentRankType === "daily" ? "看看哪位小杰泥先上榜～" : "暂时还没有总榜数据。"}</div></div>`;
          return;
        }
        const currentUsername = currentUser?.user_metadata?.username || currentUser?.email?.split("@")[0] || "";
        data.forEach((row, idx) => {
          const mins = Number(row.total_minutes || 0);
          const isMe = (row.user_id && currentUser && row.user_id === currentUser.id) || (row.username === currentUsername);
          const div = document.createElement("div");
          div.className = "item" + (isMe ? " me" : "");
          div.innerHTML = `<div style="width:34px;text-align:center">${idx === 0 ? '👑' : idx + 1}</div><div class="main"><div>${esc(row.username || "学习者")}${isMe ? '<span style="font-size:12px;color:var(--accent);">（我）</span>' : ""}</div><div class="small muted">${currentRankType === "daily" ? "今日学习时长" : "总学习时长"}：${formatMinutes(mins)}</div></div>`;
          el.leaderList.appendChild(div);
        });
      } catch (err) { console.error("loadLeaderboard error:", err); el.leaderList.innerHTML = `<div class="item"><div class="main danger">读取排行榜失败，请稍后重试。</div></div>`; } finally { leaderboardLoading = false; setButtonLoading(el.refreshLeaderboardBtn, "", false); }
    }

    async function loadHistory() {
      if (!currentUser || historyLoading) return;
      historyLoading = true; setButtonLoading(el.refreshHistoryBtn, "刷新中...", true);
      try {
        const { data, error } = await supabase.from("study_sessions").select("duration_minutes, created_at").eq("user_id", currentUser.id).order("created_at", { ascending: false }).limit(50);
        el.historyList.innerHTML = "";
        if (error) throw error;
        if (!data.length) { el.historyList.innerHTML = '<div class="item"><div class="main muted">还没有学习记录。快去完成一次专注吧！</div></div>'; return; }
        data.forEach(row => {
          const div = document.createElement("div"); div.className = "item";
          div.innerHTML = `<div class="main"><div>${new Date(row.created_at).toLocaleString("zh-CN")}</div><div class="small muted">${formatMinutes(Number(row.duration_minutes || 0))}</div></div>`;
          el.historyList.appendChild(div);
        });
      } catch (err) { el.historyList.innerHTML = '<div class="item"><div class="main danger">读取历史失败，请稍后重试。</div></div>'; } finally { historyLoading = false; setButtonLoading(el.refreshHistoryBtn, "", false); }
    }

    function startTimer() {
      if (!currentUser || timer) return;
      startedAt = Date.now(); el.statusText.textContent = "专注正在进行...";
      timer = setInterval(async () => {
        remaining -= 1; updateTimer();
        if (remaining <= 0) { clearInterval(timer); timer = null; remaining = 0; updateTimer(); await saveStudySession(Math.floor(selectedDuration / 60)); resetTimer(false); }
      }, 1000);
    }

    function pauseTimer() { if (timer) { clearInterval(timer); timer = null; el.statusText.textContent = "已暂停。"; } }
    function resetTimer(st = true) { clearInterval(timer); timer = null; remaining = selectedDuration; startedAt = null; timerMode = "countdown"; updateTimer(); if (st) el.statusText.textContent = "现在只做这一件事。"; }

    function bindTabs() {
      document.querySelectorAll("[data-auth-tab]").forEach(btn => btn.addEventListener("click", () => {
        document.querySelectorAll("[data-auth-tab]").forEach(x => x.classList.remove("active")); btn.classList.add("active");
        const tab = btn.getAttribute("data-auth-tab"); $("loginPane").classList.toggle("hidden", tab !== "login"); $("signupPane").classList.toggle("hidden", tab !== "signup");
      }));
      document.querySelectorAll("[data-side-tab]").forEach(btn => btn.addEventListener("click", () => {
        document.querySelectorAll("[data-side-tab]").forEach(x => x.classList.remove("active")); btn.classList.add("active");
        const tab = btn.getAttribute("data-side-tab"); $("tasksPane").classList.toggle("hidden", tab !== "tasks"); $("leaderboardPane").classList.toggle("hidden", tab !== "leaderboard"); $("historyPane").classList.toggle("hidden", tab !== "history");
      }));
    }

    function bindCommon() {
      document.querySelectorAll("[data-time]").forEach(btn => btn.addEventListener("click", () => {
        if (timer) return;
        document.querySelectorAll("[data-time]").forEach(x => x.classList.remove("time-btn-active")); btn.classList.add("time-btn-active");
        selectedDuration = Number(btn.dataset.time); remaining = selectedDuration; updateTimer();
        document.getElementById("modeText").textContent = "当前专注：" + Math.floor(selectedDuration / 60) + "分钟";
        el.saveManualBtn.textContent = "手动记 " + Math.floor(selectedDuration / 60) + " 分钟";
      }));
      el.themeBtn.addEventListener("click", () => {
        document.body.classList.toggle("dark"); const dark = document.body.classList.contains("dark");
        localStorage.setItem(THEME_KEY, dark ? "dark" : "light"); el.themeBtn.textContent = dark ? "☀" : "☾";
      });
      el.fullBtn.addEventListener("click", async () => { if (!document.fullscreenElement) await document.documentElement.requestFullscreen(); else await document.exitFullscreen(); });
      el.logoutBtn.addEventListener("click", logout); el.loginBtn.addEventListener("click", login); el.signupBtn.addEventListener("click", signup);
      el.startBtn.addEventListener("click", startTimer); el.pauseBtn.addEventListener("click", pauseTimer); el.resetBtn.addEventListener("click", () => resetTimer(true));
      el.saveManualBtn.addEventListener("click", () => showUndoToast(Math.floor(selectedDuration / 60)));

      // 点击计时器切换正计时/倒计时
      el.timer.addEventListener("click", () => {
        if (!timer) return; // 只在计时中才能切换
        timerMode = timerMode === "countdown" ? "countup" : "countdown";
        updateTimer();
        const modeText = timerMode === "countdown" ? "剩余时间" : "已用时间";
        showMessage(`切换为${modeText}模式`);
      });

      const applyCustomTime = () => {
        if (timer) return;
        const val = parseInt(document.getElementById("customMinInput").value, 10);
        if (isNaN(val) || val <= 0 || val > 600) { showMessage("请输入 1~600 之间的分钟数。"); return; }
        document.querySelectorAll("[data-time]").forEach(x => x.classList.remove("time-btn-active"));
        selectedDuration = val * 60;
        remaining = selectedDuration;
        updateTimer();
        document.getElementById("modeText").textContent = "当前专注：" + val + "分钟";
        el.saveManualBtn.textContent = "手动记 " + val + " 分钟";
        el.saveManualBtn.dataset.originalText = "手动记 " + val + " 分钟";
      };
      document.getElementById("customTimeBtn").addEventListener("click", applyCustomTime);
      document.getElementById("customMinInput").addEventListener("keydown", e => { if (e.key === "Enter") applyCustomTime(); });

      const prioritySelect = document.getElementById("taskPrioritySelect");
      if (prioritySelect) {
        const updatePriorityStyle = () => {
          const val = prioritySelect.value;
          prioritySelect.style.backgroundColor =
            val === "high" ? "rgba(239,68,68,0.1)" :
            val === "medium" ? "rgba(245,158,11,0.1)" :
            "rgba(156,163,175,0.05)";
          prioritySelect.style.borderColor =
            val === "high" ? "rgba(239,68,68,0.3)" :
            val === "medium" ? "rgba(245,158,11,0.3)" :
            "rgba(156,163,175,0.2)";
        };
        prioritySelect.addEventListener("change", updatePriorityStyle);
        updatePriorityStyle();
      }

      el.addTaskBtn.addEventListener("click", async () => {
        const text = el.taskInput.value.trim();
        const timeInput = document.getElementById("taskTimeInput");
        const prioritySelect = document.getElementById("taskPrioritySelect");
        const durationMinutes = parseInt(timeInput.value, 10);
        const priority = prioritySelect.value;

        if (!text) {
          showMessage("请输入任务内容。");
          return;
        }
        if (!durationMinutes || durationMinutes <= 0) {
          showMessage("请输入任务时长（分钟）。");
          return;
        }

        await addTaskToSupabase(text, selectedTaskDate, durationMinutes, priority);
        el.taskInput.value = "";
        timeInput.value = "";
        prioritySelect.value = "medium";
      });
      el.taskInput.addEventListener("keydown", e => { if (e.key === "Enter") el.addTaskBtn.click(); });

      // 移动端抽屉逻辑
      let selectedDrawerPriority = "medium";

      if (el.mobileAddTaskBtn) {
        el.mobileAddTaskBtn.addEventListener("click", () => {
          el.taskDrawer.classList.add("show");
          el.drawerOverlay.classList.add("show");
        });
      }

      if (el.closeDrawerBtn) {
        el.closeDrawerBtn.addEventListener("click", () => {
          el.taskDrawer.classList.remove("show");
          el.drawerOverlay.classList.remove("show");
        });
      }

      if (el.drawerOverlay) {
        el.drawerOverlay.addEventListener("click", () => {
          el.taskDrawer.classList.remove("show");
          el.drawerOverlay.classList.remove("show");
        });
      }

      // 抽屉优先级选择
      const drawerPriorityBtns = document.querySelectorAll(".drawer-priority-btn");
      drawerPriorityBtns.forEach(btn => {
        btn.addEventListener("click", () => {
          drawerPriorityBtns.forEach(b => {
            b.classList.remove("active-high", "active-medium", "active-low");
          });
          selectedDrawerPriority = btn.dataset.priority;
          btn.classList.add(`active-${selectedDrawerPriority}`);
        });
      });

      // 抽屉添加任务
      if (el.drawerAddBtn) {
        el.drawerAddBtn.addEventListener("click", async () => {
          const text = el.drawerTaskInput.value.trim();
          if (!text) {
            showMessage("请输入任务内容。");
            return;
          }

          const durationMinutes = parseInt(el.drawerDurationInput.value);
          if (!durationMinutes || durationMinutes <= 0) {
            showMessage("请输入任务时长（分钟）。");
            return;
          }

          await addTaskToSupabase(text, selectedTaskDate, durationMinutes, selectedDrawerPriority);

          // 清空输入并关闭抽屉
          el.drawerTaskInput.value = "";
          el.drawerDurationInput.value = "";
          selectedDrawerPriority = "medium";
          drawerPriorityBtns.forEach(b => {
            b.classList.remove("active-high", "active-medium", "active-low");
          });
          drawerPriorityBtns[1].classList.add("active-medium");

          el.taskDrawer.classList.remove("show");
          el.drawerOverlay.classList.remove("show");
        });
      }

      el.taskDatePicker.addEventListener("change", async (e) => {
        if (e.target.value) {
          selectedTaskDate = e.target.value;
          await loadTasksByDate(selectedTaskDate);
        }
      });
      el.goTodayBtn.addEventListener("click", async () => {
        selectedTaskDate = getLocalDateISO();
        el.taskDatePicker.value = selectedTaskDate;
        await loadTasksByDate(selectedTaskDate);
      });
      el.goYesterdayBtn.addEventListener("click", () => changeTaskDate(-1));

      el.dailyRankTab.addEventListener("click", () => {
        if(currentRankType === "daily") return;
        currentRankType = "daily";
        el.dailyRankTab.classList.add("active");
        el.totalRankTab.classList.remove("active");
        loadLeaderboard();
      });

      el.totalRankTab.addEventListener("click", () => {
        if(currentRankType === "total") return;
        currentRankType = "total";
        el.totalRankTab.classList.add("active");
        el.dailyRankTab.classList.remove("active");
        loadLeaderboard();
      });

      el.refreshLeaderboardBtn.addEventListener("click", loadLeaderboard); el.refreshHistoryBtn.addEventListener("click", loadHistory);
      el.editGoalBtn.addEventListener("click", () => {
        const input = prompt("请输入目标学习时长（分钟）：", dailyGoal); if (input === null) return;
        const val = parseInt(input, 10); if (isNaN(val) || val <= 0) { showMessage("请输入大于 0 的有效分钟数。"); return; }
        dailyGoal = val; saveJSON(GOAL_KEY, dailyGoal); loadMyStats();
      });
      el.checkinBtn.addEventListener("click", handleCheckin);
      el.immersiveBtn.addEventListener("click", () => { document.body.classList.add("immersive"); el.exitImmersiveBtn.classList.remove("hidden"); if (!document.fullscreenElement) { document.documentElement.requestFullscreen().catch(()=>{}); } });
      el.exitImmersiveBtn.addEventListener("click", () => { document.body.classList.remove("immersive"); el.exitImmersiveBtn.classList.add("hidden"); if (document.fullscreenElement) { document.exitFullscreen().catch(()=>{}); } });

      if (el.openHeatmapBtn) {
        el.openHeatmapBtn.addEventListener("click", async () => {
          currentHeatmapRange = 30;
          currentSubjectFilter = "全部";
          if (el.heatmap30Btn) el.heatmap30Btn.classList.add("active");
          if (el.heatmap365Btn) el.heatmap365Btn.classList.remove("active");
          showHeatmapPage();
          await loadSubjectList();
          await renderHeatmap();
        });
      }
      if (el.backToMainBtn) {
        el.backToMainBtn.addEventListener("click", () => {
          showMainPage();
        });
      }
      if (el.refreshHeatmapBtn) {
        el.refreshHeatmapBtn.addEventListener("click", async () => {
          await renderHeatmap();
        });
      }

      if (el.heatmap30Btn) {
        el.heatmap30Btn.addEventListener("click", async () => {
          if (currentHeatmapRange === 30) return;
          currentHeatmapRange = 30;
          el.heatmap30Btn.classList.add("active");
          el.heatmap365Btn.classList.remove("active");
          await renderHeatmap();
        });
      }
      if (el.heatmap365Btn) {
        el.heatmap365Btn.addEventListener("click", async () => {
          if (currentHeatmapRange === 365) return;
          currentHeatmapRange = 365;
          el.heatmap365Btn.classList.add("active");
          el.heatmap30Btn.classList.remove("active");
          await renderHeatmap();
        });
      }

      const subjectFilterEl = document.getElementById("subjectFilter");
      if (subjectFilterEl) {
        subjectFilterEl.addEventListener("change", async (e) => {
          currentSubjectFilter = e.target.value;
          await renderHeatmap();
        });
      }

      document.querySelectorAll("[data-range]").forEach(btn => btn.addEventListener("click", async () => {
        document.querySelectorAll("[data-range]").forEach(x => x.classList.remove("active"));
        btn.classList.add("active");
        const range = btn.getAttribute("data-range");
        await loadSubjectStats(range);
      }));
    }

    async function refreshSession() {
      try {
        const { data, error } = await supabase.auth.getUser();
        if (error) throw error;
        
        currentUser = data.user || null;
        updateAuthUI();
        
        if (currentUser) {
          await ensureProfile();
          await Promise.all([
            loadMyStats(),
            loadHistory(),
            loadCheckinInfo(),
            loadLeaderboard(),
            loadTasksByDate(selectedTaskDate)
          ]);
        } else {
          currentTasks = [];
          renderTasks();
          await loadLeaderboard();
        }
      } catch (err) {
        console.error("refreshSession error:", err);
        setAppStatus("登录状态恢复失败，请刷新重试。", "error");
      } finally {
        appReady = true;
        setInteractiveState(true);
        setAppStatus(""); 
      }
    }

    async function main() {
      try {
        const theme = localStorage.getItem(THEME_KEY); 
        if (theme === "dark") { 
          document.body.classList.add("dark"); 
          el.themeBtn.textContent = "☀"; 
        }
        
        selectedTaskDate = getLocalDateISO();
        el.taskDatePicker.value = selectedTaskDate;
        
        bindTabs(); bindCommon(); renderTasks(); updateTimer();
        
        setInteractiveState(false); 
        setAppStatus("正在初始化...");
        
        if (!localStorage.getItem("today_opened_v2_" + getLocalDateISO())) { 
          setTimeout(() => alert("今天也要保持专注哦 🔥"), 500); 
          localStorage.setItem("today_opened_v2_" + getLocalDateISO(), "true"); 
        }
        
        supabase.auth.onAuthStateChange((event, session) => {
          currentUser = session?.user || null;
          updateAuthUI();

          if (event === "SIGNED_IN" || event === "SIGNED_OUT") {
            setTimeout(() => {
              refreshSession();
            }, 0);
          }
        });
        
        await refreshSession();
        
      } catch (err) { 
        console.error("main error:", err);
        setAppStatus("连接失败，请刷新重试。", "error"); 
      }
    }
    main();
  </script>

  <!-- 移动端任务抽屉 -->
  <div class="drawer-overlay" id="drawerOverlay"></div>
  <div class="task-drawer" id="taskDrawer">
    <div class="drawer-header">
      <div class="drawer-title">添加新任务</div>
      <button class="drawer-close" id="closeDrawerBtn">×</button>
    </div>

    <div class="drawer-field">
      <label class="drawer-label">任务内容</label>
      <input class="drawer-input" id="drawerTaskInput" type="text" placeholder="输入任务内容..." />
    </div>

    <div class="drawer-field">
      <label class="drawer-label">预计时长（分钟）</label>
      <input class="drawer-input" id="drawerTimeInput" type="number" min="1" max="600" placeholder="例如：30" />
    </div>

    <div class="drawer-field">
      <label class="drawer-label">优先级</label>
      <div class="drawer-priority-grid">
        <button class="drawer-priority-btn" data-priority="high">🔴 优先做</button>
        <button class="drawer-priority-btn active-medium" data-priority="medium">🟡 重点做</button>
        <button class="drawer-priority-btn" data-priority="low">⚪ 有时间做</button>
      </div>
    </div>

    <button class="btn primary" id="drawerAddBtn" style="width:100%; padding:14px; margin-top:8px;">添加任务</button>
  </div>
</body>
</html>
